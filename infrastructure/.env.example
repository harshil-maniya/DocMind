# =============================================
# DocMind Infrastructure - Environment Variables
# =============================================

# ----- General -----
NODE_ENV=production

# ----- JWT Auth (REQUIRED - change these!) -----
JWT_SECRET=change-me-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-super-secret-refresh-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ----- Database (PostgreSQL + pgvector) -----
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=docmind
DB_PASSWORD=change-me-strong-password
DB_DATABASE=docmind
DB_SSL=false
DB_SYNCHRONIZE=true

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- AWS S3 (REQUIRED for document upload) -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=docmind-documents
S3_PRESIGNED_URL_EXPIRES=3600

# ----- OpenAI (REQUIRED) -----
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ----- Service Ports -----
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
DOC_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
QUERY_SERVICE_PORT=3004
ANALYTICS_SERVICE_PORT=3005

# ----- Rate Limiting -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- Chunking -----
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ----- Semantic Cache -----
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600

# ----- Retrieval -----
RETRIEVAL_TOP_K=10
RETRIEVAL_VECTOR_WEIGHT=0.7
RETRIEVAL_KEYWORD_WEIGHT=0.3

# ----- Analytics -----
OPENAI_COST_PER_1K_INPUT_TOKENS=0.01
OPENAI_COST_PER_1K_OUTPUT_TOKENS=0.03

# ----- CORS -----
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
