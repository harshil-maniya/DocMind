# =============================================
# DocMind - Environment Variables Example
# =============================================
# Copy this file to .env and fill in values

# ----- General -----
NODE_ENV=development

# ----- JWT Auth -----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ----- Database (PostgreSQL + pgvector) -----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=docmind
DB_PASSWORD=docmind_password
DB_DATABASE=docmind
DB_SSL=false
DB_SYNCHRONIZE=true
DB_LOGGING=false

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ----- AWS S3 -----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_NAME=docmind-documents
S3_PRESIGNED_URL_EXPIRES=3600

# ----- OpenAI -----
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ----- Service Ports -----
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
DOC_SERVICE_PORT=3002
AI_SERVICE_PORT=3003
QUERY_SERVICE_PORT=3004
ANALYTICS_SERVICE_PORT=3005

# ----- Service URLs (used by API Gateway) -----
AUTH_SERVICE_URL=http://localhost:3001
DOC_SERVICE_URL=http://localhost:3002
AI_SERVICE_URL=http://localhost:3003
QUERY_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005

# ----- Rate Limiting -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- Chunking -----
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ----- Semantic Cache -----
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600

# ----- Retrieval -----
RETRIEVAL_TOP_K=10
RETRIEVAL_VECTOR_WEIGHT=0.7
RETRIEVAL_KEYWORD_WEIGHT=0.3

# ----- Analytics -----
OPENAI_COST_PER_1K_INPUT_TOKENS=0.01
OPENAI_COST_PER_1K_OUTPUT_TOKENS=0.03

# ----- CORS -----
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
